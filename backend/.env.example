# ==========================================================
# Market Intelligence AI - Backend
# Copie este arquivo para .env e preencha com suas chaves reais.
# O .env NUNCA deve ser commitado (ja esta no .gitignore).
# ==========================================================

# --- Banco de dados ---
# LOCAL: porta 5434 no host (mapeada para 5432 no container) para evitar
# conflito com outros projetos. Veja docker-compose.yml.
# PRODUCAO (Railway): NAO setar isto. O Railway injeta DATABASE_URL
# automaticamente; o codigo normaliza o schema para asyncpg.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5434/market_intelligence

# --- Redis (broker do Celery) ---
# LOCAL: porta 6380 no host. PRODUCAO: Railway injeta REDIS_URL automaticamente.
REDIS_URL=redis://localhost:6380/0

# --- LLMs ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Pesquisa ---
PERPLEXITY_API_KEY=
GROK_API_KEY=
SERPER_API_KEY=

# --- Reddit (deixar vazio para usar mock) ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# --- Pipeline ---
PIPELINE_INTERVAL_SECONDS=3600
PIPELINE_TOPICS_PER_RUN=5
MIN_SCORE_TO_KEEP=6.0
MIN_SCORE_FOR_PROJECT_PLAN=8.0

# --- App ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- CORS ---
# LOCAL: deixar vazio (libera tudo). PRODUCAO: setar no Railway com a URL
# da Vercel, ex: ALLOWED_ORIGINS=https://seu-app.vercel.app
# (pode listar varias separadas por virgula).
ALLOWED_ORIGINS=

# --- Modelos (opcional: ja tem default no codigo; descomente para sobrescrever) ---
# ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_MODEL=gpt-5.5
# PERPLEXITY_MODEL=sonar-pro
# GROK_MODEL=grok-4.3
