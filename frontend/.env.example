# URL do backend FastAPI (usada pelo navegador nas leituras).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Chave dos endpoints de controle (server-side APENAS — sem NEXT_PUBLIC).
# Injetada pelo proxy /api/control/* no header X-API-Key.
# Deve ser a MESMA CONTROL_API_KEY configurada no backend.
CONTROL_API_KEY=

# --- Autenticacao do painel (usuario unico) ---
# Email autorizado a logar.
APP_LOGIN_EMAIL=voce@exemplo.com
# Hash scrypt da senha. Gere com: node scripts/hash-password.mjs 'sua-senha'
# Formato: scrypt$<salt>$<hash>. NUNCA commitar a senha em texto.
APP_LOGIN_PASSWORD_HASH=
# Segredo p/ assinar o cookie de sessao (HMAC). Gere: openssl rand -hex 32
SESSION_SECRET=

# --- Backend (server-side; NUNCA usar NEXT_PUBLIC_ nestes) ---
# URL do backend FastAPI, usada pelos proxies server-side (/api/data, /api/control).
API_URL=http://localhost:8000
# Chave de LEITURA do backend (mesma READ_API_KEY do backend). Injetada pelo
# proxy /api/data. NUNCA como NEXT_PUBLIC_*.
READ_API_KEY=

# --- Observabilidade (Sentry) ---
# DSN do projeto Sentry 'market-intelligence-frontend' (org capivarex-real).
# NEXT_PUBLIC_ = usado no navegador; SENTRY_DSN (server-side) pode ser o mesmo valor.
# Vazio = Sentry desligado (no-op).
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
